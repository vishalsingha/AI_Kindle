<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow Electron to JIT-compile JavaScript -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required for pdf.js worker + native modules like better-sqlite3 -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Allow reading user-selected files (for importing PDFs) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- Allow loopback network so the app can talk to Ollama on localhost -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Required for the app to spawn child processes (pdf.js worker) -->
  <key>com.apple.security.cs.disable-executable-page-protection</key>
  <true/>
</dict>
</plist>
